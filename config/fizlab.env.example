# FizLab - configuração padrão
# Copie para "$SERVER_HOME/config/fizlab.env" e ajuste quando necessário.

FIZLAB_HTTP_HOST=0.0.0.0
FIZLAB_HTTP_PORT=8080
FIZLAB_API_HOST=127.0.0.1
FIZLAB_API_PORT=8765
FIZLAB_DASHBOARD_REFRESH_SECONDS=10
FIZLAB_WATCHDOG_INTERVAL_MINUTES=5
FIZLAB_WATCHDOG_MAX_ATTEMPTS=3
FIZLAB_WATCHDOG_COOLDOWN_SECONDS=300
FIZLAB_LOG_MAX_SIZE_MB=5
FIZLAB_LOG_RETENTION_DAYS=30
FIZLAB_LOG_ROTATIONS=5
FIZLAB_LOG_TAIL_MAX_LINES=500
FIZLAB_LOG_TAIL_MAX_BYTES=262144

# Acesso remoto seguro — Sprint 5
# Mantenha "lan" até validar o Tailscale; use "tailnet" para permitir o
# dashboard somente por localhost e pela rede privada Tailscale.
FIZLAB_DASHBOARD_ACCESS=lan
FIZLAB_TAILSCALE_CIDRS=100.64.0.0/10,fd7a:115c:a1e0::/48
# A configuração de SSH só é aplicada por "fizlab-remote secure-ssh --apply".
FIZLAB_SSH_HARDENING=disabled
FIZLAB_SSH_ACCESS=tailnet
